# HealthPulse Environment Variables
# Copy this file to .env and fill in the values

# Application
VITE_API_URL=http://localhost:3000/api
VITE_ENV=development
VITE_APP_VERSION=1.0.0

# Docker
APP_PORT=3000

# Datadog (for monitoring integration)
DD_API_KEY=your_datadog_api_key_here
DD_SITE=datadoghq.com

# SonarQube (for CI pipeline)
SONAR_HOST_URL=http://sonarqube:9000
SONAR_TOKEN=your_sonar_token_here

# Snyk (for CI pipeline)
SNYK_TOKEN=your_snyk_token_here

# Artifactory (for CI pipeline)
ARTIFACTORY_URL=https://your-instance.jfrog.io
ARTIFACTORY_USER=your_user
ARTIFACTORY_PASSWORD=your_password

# AWS (for Terraform)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
